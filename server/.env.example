PORT=5000
MONGODB_URI=mongodb://localhost:27017/veag
# OR use MongoDB Atlas connection string:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/veag?retryWrites=true&w=majority

# Razorpay Configuration
RAZORPAY_KEY_ID=your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here


# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here


# Gradio AI Model Configuration
GRADIO_SPACE_URL=your_gradio_space_url_here

# Gemini AI Configuration (for treatment/causes/prevention)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
# Optional: Override default prompts (use {disease} as placeholder for disease name)
# GEMINI_TREATMENT_PROMPT=Your custom treatment prompt here with {disease} placeholder
# GEMINI_CAUSES_PROMPT=Your custom causes prompt here with {disease} placeholder
# GEMINI_PREVENTION_PROMPT=Your custom prevention prompt here with {disease} placeholder